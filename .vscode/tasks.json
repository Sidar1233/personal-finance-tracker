{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": ["build", "${workspaceFolder}/Payzo.csproj", "--configuration", "Debug"],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "command": "dotnet",
      "type": "process",
      "args": ["run", "--project", "${workspaceFolder}/Payzo.csproj"],
      "problemMatcher": "$msCompile",
      "isBackground": true
    }
  ]
}
