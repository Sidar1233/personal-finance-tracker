@model TransactionsViewModel
@{
    ViewData["Title"] = "Транзакции";
    ViewData["Subtitle"] = "Преглед и управление на всички транзакции";
    ViewData["ActiveNav"] = "transactions";
    var categories = new[]{"Храна","Транспорт","Забавление","Здраве","Наем","Заплата","Различно","Спестявания"};
}

<div class="grid-3 section-gap">
  <div class="stat-card"><div class="stat-icon" style="background:#dcfce7">📥</div><div class="stat-label">Общо приходи</div><div class="stat-value" style="color:#16a34a">@Model.TotalIncome.ToString("F2")€</div></div>
  <div class="stat-card"><div class="stat-icon" style="background:#fee2e2">📤</div><div class="stat-label">Общо разходи</div><div class="stat-value" style="color:#dc2626">@Model.TotalExpenses.ToString("F2")€</div></div>
  <div class="stat-card"><div class="stat-icon" style="background:#fef3c7">💰</div><div class="stat-label">Нетно</div><div class="stat-value" style="color:#f59e0b">@((Model.TotalIncome-Model.TotalExpenses).ToString("F2"))€</div></div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">💳 Транзакции</span>
    <button class="btn btn-primary btn-sm" onclick="openModal('modal-add')">+ Нова транзакция</button>
  </div>

  <form method="get" action="/Transactions" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;align-items:flex-end">
    <div class="form-group" style="margin:0;flex:1;min-width:150px">
      <label class="form-label">Търсене</label>
      <input name="search" class="form-control" placeholder="Описание..." value="@Model.FilterSearch">
    </div>
    <div class="form-group" style="margin:0;min-width:140px">
      <label class="form-label">Тип</label>
      <select name="type" class="form-control">
        <option value="">Всички</option>
        <option value="income" selected="@(Model.FilterType=="income" ? "selected" : null)">Приходи</option>
        <option value="expense" selected="@(Model.FilterType=="expense" ? "selected" : null)">Разходи</option>
      </select>
    </div>
    <div class="form-group" style="margin:0;min-width:140px">
      <label class="form-label">Категория</label>
      <select name="category" class="form-control">
        <option value="">Всички</option>
        @foreach (var c in categories)
        {
          <option value="@c" selected="@(Model.FilterCategory==c ? "selected" : null)">@c</option>
        }
      </select>
    </div>
    <button type="submit" class="btn btn-ghost btn-sm">🔍 Филтрирай</button>
  </form>

  @if (!Model.Transactions.Any())
  {
    <div class="empty-state"><div class="icon">📭</div><h4>Няма транзакции</h4></div>
  }
  else
  {
    <div class="table-wrapper">
      <table class="payzo-table">
        <thead><tr><th></th><th>Описание</th><th>Категория</th><th>Дата</th><th>Тип</th><th class="text-right">Сума</th><th></th></tr></thead>
        <tbody>
          @foreach (var t in Model.Transactions)
          {
            <tr>
              <td><div style="width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;background:@(t.Type==TransactionType.Income?"#dcfce7":"#fee2e2")">@t.Icon</div></td>
              <td><strong>@t.Description</strong></td>
              <td><span class="badge badge-blue">@t.Category</span></td>
              <td style="color:#475569">@t.Date.ToString("dd MMM yyyy")</td>
              <td><span style="padding:3px 10px;border-radius:100px;font-size:.75rem;font-weight:700;background:@(t.Type==TransactionType.Income?"#dcfce7":"#fee2e2");color:@(t.Type==TransactionType.Income?"#166534":"#991b1b")">@(t.Type==TransactionType.Income?"Приход":"Разход")</span></td>
              <td class="text-right @(t.Type==TransactionType.Income?"text-income":"text-expense")">@(t.Type==TransactionType.Income?"+":"-")@t.Amount.ToString("F2")€</td>
              <td>
                <div style="display:flex;gap:6px;justify-content:flex-end">
                  <button class="btn btn-ghost btn-sm" onclick="editTxn('@t.Id','@t.Type','@t.Amount','@t.Category','@t.Description','@t.Icon','@t.Date.ToString("yyyy-MM-dd")')">✏️</button>
                  <form method="post" action="/Transactions/Delete" style="display:inline" onsubmit="return confirm('Изтриване?')">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@t.Id">
                    <button type="submit" class="btn btn-ghost btn-sm">🗑️</button>
                  </form>
                </div>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

<!-- Add modal -->
<div class="modal-backdrop" id="modal-add">
  <div class="modal">
    <div class="modal-header"><h3 id="modal-title">➕ Нова транзакция</h3><button class="modal-close">✕</button></div>
    <div class="modal-body">
      <form id="txn-form" method="post" action="/Transactions/Add">
        @Html.AntiForgeryToken()
        <input type="hidden" id="form-action-url" name="">
        <div class="grid-2">
          <div class="form-group"><label class="form-label">Тип</label>
            <select id="f-type" name="type" class="form-control"><option value="Expense">Разход</option><option value="Income">Приход</option></select></div>
          <div class="form-group"><label class="form-label">Сума (€)</label>
            <input id="f-amount" name="amount" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00"></div>
        </div>
        <div class="form-group"><label class="form-label">Описание</label><input id="f-desc" name="description" class="form-control" placeholder="Lidl, Заплата..."></div>
        <div class="grid-2">
          <div class="form-group"><label class="form-label">Категория</label>
            <select id="f-cat" name="category" class="form-control">
              @foreach (var c in categories) { <option>@c</option> }
            </select></div>
          <div class="form-group"><label class="form-label">Дата</label>
            <input id="f-date" name="date" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")"></div>
        </div>
        <div class="form-group"><label class="form-label">Икона</label>
          <input type="hidden" id="f-icon" name="icon" value="💳">
          <div id="f-icon-picker" class="emoji-picker">
            @foreach (var e in new[]{"💳","🛒","🍕","🚗","⛽","🚌","🎬","🎮","💊","🏠","💰","💵","🛍️","☕","🍔","✈️","🏋️","📱","💻","🎓","🎸","⚽","🎁","🐶","🌍","🏖️","🎪","📚","💎","🎨"})
            {
              <button type="button" class="emoji-btn" onclick="pickEmoji('f-icon','f-icon-picker',this,this.textContent.trim())">@e</button>
            }
          </div>
        </div>
      </form>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost" onclick="closeModal('modal-add')">Отказ</button>
      <button class="btn btn-primary" onclick="document.getElementById('txn-form').submit()">💾 Запази</button>
    </div>
  </div>
</div>

<script>
function editTxn(id,type,amount,cat,desc,icon,date){
  document.getElementById('txn-form').action='/Transactions/Edit';
  var form = document.getElementById('txn-form');
  var hid = form.querySelector('input[name=id]') || document.createElement('input');
  hid.type='hidden'; hid.name='id'; hid.value=id;
  form.appendChild(hid);
  document.getElementById('f-type').value=type;
  document.getElementById('f-amount').value=amount;
  document.getElementById('f-cat').value=cat;
  document.getElementById('f-desc').value=desc;
  document.getElementById('f-icon').value=icon;
  syncEmojiPicker('f-icon-picker', icon);
  document.getElementById('f-date').value=date;
  document.getElementById('modal-title').textContent='✏️ Редактиране';
  openModal('modal-add');
}
</script>
