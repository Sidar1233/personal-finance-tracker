@model Payzo.Models.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="bg">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Payzo – Вход</title>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body{background:linear-gradient(135deg,#0d3080,#1a4fb5 50%,#2563eb);display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}
    .box{background:#fff;border-radius:24px;padding:48px 44px;width:100%;max-width:440px;box-shadow:0 40px 100px rgba(0,0,0,.3)}
    .logo-wrap{text-align:center;margin-bottom:28px}
    .logo-wrap img{height:56px;object-fit:contain}
    h1{font-family:Montserrat,sans-serif;font-weight:800;font-size:1.6rem;text-align:center;color:#0d3080;margin-bottom:6px}
    .subtitle{text-align:center;color:#475569;font-size:.92rem;margin-bottom:28px}
    .form-group{margin-bottom:18px}
    .form-label{display:block;font-weight:600;font-size:.85rem;color:#374151;margin-bottom:6px}
    .form-control{width:100%;padding:12px 16px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:.95rem;outline:none;transition:border .2s;font-family:Inter,sans-serif}
    .form-control:focus{border-color:#1a4fb5;box-shadow:0 0 0 3px rgba(26,79,181,.1)}
    .btn-primary{width:100%;padding:14px;background:#1a4fb5;color:#fff;border:none;border-radius:12px;font-family:Montserrat,sans-serif;font-weight:700;font-size:1rem;cursor:pointer;margin-top:8px;transition:all .2s}
    .btn-primary:hover{background:#0d3080;transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,79,181,.3)}
    .register-link{text-align:center;margin-top:20px;font-size:.9rem;color:#475569}
    .register-link a{color:#1a4fb5;font-weight:600;text-decoration:none}
    .register-link a:hover{text-decoration:underline}
    .alert-error{background:#fef2f2;color:#dc2626;padding:12px 16px;border-radius:10px;margin-bottom:16px;font-size:.88rem;border:1px solid #fecaca}
    .alert-success{background:#f0fdf4;color:#16a34a;padding:12px 16px;border-radius:10px;margin-bottom:16px;font-size:.88rem;border:1px solid #bbf7d0}
  </style>
</head>
<body>
<div class="box">
  <div class="logo-wrap">
    <img src="/images/logo.png" alt="Payzo">
  </div>
  <h1>Добре дошли!</h1>
  <p class="subtitle">Влезте в акаунта си</p>

  @if(TempData["Success"] != null)
  {
    <div class="alert-success">✅ @TempData["Success"]</div>
  }
  @if(!string.IsNullOrEmpty(Model?.Error))
  {
    <div class="alert-error">❌ @Model.Error</div>
  }

  <form method="post" action="/Account/Login">
    @Html.AntiForgeryToken()
    <div class="form-group">
      <label class="form-label">Имейл адрес</label>
      <input name="Email" type="email" class="form-control" placeholder="вашият@имейл.bg" value="@Model?.Email" autocomplete="email">
    </div>
    <div class="form-group">
      <label class="form-label">Парола</label>
      <input name="Password" type="password" class="form-control" placeholder="Въведете парола" autocomplete="current-password">
    </div>
    <button type="submit" class="btn-primary">Вход →</button>
  </form>

  <div class="register-link">
    Нямате акаунт? <a href="/Account/Register">Регистрирайте се безплатно</a>
  </div>
</div>
</body>
</html>