@using System.Security.Claims
@{
    var name        = User.FindFirst(ClaimTypes.Name)?.Value ?? "";
    var role        = User.FindFirst(ClaimTypes.Role)?.Value ?? "User";
    var avatar      = User.FindFirst("Avatar")?.Value ?? "?";
    var avatarColor = User.FindFirst("AvatarColor")?.Value ?? "#1a4fb5";
    var active      = ViewData["ActiveNav"]?.ToString() ?? "";

    var roleLabel = role switch {
        "SuperAdmin" => "Супер Администратор",
        "Admin"      => "Администратор",
        _            => "Потребител"
    };
    var roleCls = role switch {
        "SuperAdmin" => "role-superadmin",
        "Admin"      => "role-admin",
        _            => "role-user"
    };
    bool isAdmin = role == "Admin" || role == "SuperAdmin";
    bool isSuperAdmin = role == "SuperAdmin";
}
<aside class="sidebar">
  <div class="sidebar-logo">
    <img src="/images/logo.png" alt="Payzo">
  </div>
  <nav class="sidebar-nav">
    <div class="nav-section-label">Основни</div>
    <a class="nav-link @(active=="dashboard"?"active":"")" href="/Dashboard/Index">
      <span class="icon">🏠</span> Табло
    </a>
    <a class="nav-link @(active=="transactions"?"active":"")" href="/Transactions/Index">
      <span class="icon">💳</span> Транзакции
    </a>
    <a class="nav-link @(active=="budget"?"active":"")" href="/Budget/Index">
      <span class="icon">🎯</span> Бюджет
    </a>
    <a class="nav-link @(active=="goals"?"active":"")" href="/Goals/Index">
      <span class="icon">🏆</span> Цели
    </a>
    @if (isAdmin)
    {
      <div class="nav-section-label">Администрация</div>
      <a class="nav-link @(active=="users"?"active":"")" href="/Users/Index">
        <span class="icon">👥</span> Потребители
      </a>
      <a class="nav-link @(active=="reports"?"active":"")" href="/Users/Reports">
        <span class="icon">📊</span> Отчети
      </a>
    }
    @if (isSuperAdmin)
    {
      <a class="nav-link @(active=="settings"?"active":"")" href="/Users/Settings">
        <span class="icon">⚙️</span> Системни настройки
      </a>
    }
  </nav>
  <div class="sidebar-user" onclick="window.location.href='/Account/Profile'">
    <div class="avatar" style="background:@avatarColor">@avatar</div>
    <div class="sidebar-user-info">
      <div class="name">@name</div>
      <div class="role"><span class="badge @roleCls" style="font-size:.65rem;padding:2px 6px">@roleLabel</span></div>
    </div>
  </div>
</aside>
